        "text_pREVqx": {
          "type": "text",
          "settings": {
            "text": "<p><a href=\"/collections/agriculture\" title=\"Agriculture\">Agriculture</a>  •  <a href=\"/collections/water\" title=\"Water\">Aquaculture</a>   •  <a href=\"/collections/aquarium\" title=\"Aquarium\">Aquariums and Pets</a> •  <a href=\"/collections/meters\" title=\"Meters\">Boilers and Cooling Towers</a> • <a href=\"/collections/brewery-beer-wine\" title=\"Brewery, Beer & Wine\">Breweries</a> • <a href=\"/collections/spectrophotometers\" title=\"Spectrophotometers\">Environmental monitoring</a> • <a href=\"/collections/food-and-drink\" title=\"Food and Drink\">Food and Dairy</a> • <a href=\"/collections/greenhouses-hydroponics\" title=\"Greenhouses & Hydroponics\">Greenhouses & Hydroponics</a> • <a href=\"/collections/testers\" title=\"Testers\">Industrial Processes</a> • <a href=\"/collections/waste-water\" title=\"Waste water\">Industrial Wastewater</a> • <a href=\"/collections/water\" title=\"Water\">Municipal Drinking and Waste Water </a>• <a href=\"/collections/meters\" title=\"Meters\">Plating</a> • <a href=\"/collections/printing-and-graphics\" title=\"Printing and Graphics\">Printing/Graphics</a> •<a href=\"/collections/meters\" title=\"Meters\"> Quality Control Laboratories</a> • <a href=\"/collections/pools-spas-and-hot-tubs\" title=\"Pools, Spas and Hot Tubs\">Swimming Pools and Spas</a> • <a href=\"/collections/water\" title=\"Water\">Water Conditioning</a> • <a href=\"/collections/water\" title=\"Water\">Water Purification</a> • <a href=\"/collections/vineyards-and-wine\" title=\"Vineyards and Wine\">Wineries</a></p>",
