{% doc %}
  @prompt
    Could you generate 4 responsive boxes to be placed under a Shopify custom Liquid section?
    Requirements:
    
    All four boxes should be displayed beside each other in a single row, responsive: 1 column on mobile, 2 on tablet, 4 on desktop.
    
    Each box should have:
    
    An image or SVG at the top
    
    A title below the image
    
    Some paragraph text below the title
    
    Optional list items (bullets) under the paragraph
    
    The boxes should be centered horizontally in the row, so that if you adjust the width on desktop, they expand evenly from the center.
    
    Each box should expand vertically to fit its content, so the height adjusts automatically depending on the text inside.
    
    Keep styling clean and minimal, with a light background for the boxes.
    
    Code should be ready to paste into a Shopify custom Liquid section, using proper HTML and classes.
    
    It should be easy to replace images, titles, text, and lists later in Shopify admin.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-info-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-info-boxes-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;
    justify-content: center;
  }

  .ai-info-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.box_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: auto;
  }

  .ai-info-box-image-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_size }}px;
    height: auto;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-info-box-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-info-box-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_size }}px;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.spacing }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-info-box-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-info-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
  }

  .ai-info-box-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    line-height: 1.5;
  }

  .ai-info-box-list-{{ ai_gen_id }} {
    list-style: disc;
    padding-left: 20px;
    margin: 0;
    text-align: left;
    width: 100%;
  }

  .ai-info-box-list-{{ ai_gen_id }} li {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-info-boxes-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-info-boxes-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<info-boxes-{{ ai_gen_id }} class="ai-info-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-info-boxes-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign box_enabled_key = 'box_' | append: i | append: '_enabled'
        assign box_image_key = 'box_' | append: i | append: '_image'
        assign box_title_key = 'box_' | append: i | append: '_title'
        assign box_text_key = 'box_' | append: i | append: '_text'
        assign box_list_key = 'box_' | append: i | append: '_list'

        assign box_enabled = block.settings[box_enabled_key]
        assign box_image = block.settings[box_image_key]
        assign box_title = block.settings[box_title_key]
        assign box_text = block.settings[box_text_key]
        assign box_list = block.settings[box_list_key]
      %}

      {% if box_enabled %}
        <div class="ai-info-box-{{ ai_gen_id }}">
          {% if box_image %}
            <div class="ai-info-box-image-{{ ai_gen_id }}">
              <img
                src="{{ box_image | image_url: width: 400 }}"
                alt="{{ box_image.alt | escape }}"
                loading="lazy"
                width="{{ box_image.width }}"
                height="{{ box_image.height }}"
              >
            </div>
          {% else %}
            <div class="ai-info-box-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if box_title != blank %}
            <h3 class="ai-info-box-title-{{ ai_gen_id }}">{{ box_title }}</h3>
          {% endif %}

          {% if box_text != blank %}
            <div class="ai-info-box-text-{{ ai_gen_id }}">{{ box_text }}</div>
          {% endif %}

          {% if box_list != blank %}
            {% assign list_items = box_list | split: ',' %}
            <ul class="ai-info-box-list-{{ ai_gen_id }}">
              {% for item in list_items %}
                {% assign trimmed_item = item | strip %}
                {% if trimmed_item != blank %}
                  <li>{{ trimmed_item }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</info-boxes-{{ ai_gen_id }}>

<script>
  (function() {
    class InfoBoxes{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('info-boxes-{{ ai_gen_id }}', InfoBoxes{{ ai_gen_id }});
  })();
</script>

