{% doc %}
  @prompt
    A box with heading and icons and a call to action link, make a background
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-background-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-background-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  .ai-background-container-{{ ai_gen_id }} {
    position: relative;
    min-height: {{ block.settings.min_height }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
  }

  {% if block.settings.background_image %}
    .ai-background-image-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: {{ block.settings.image_opacity }};
    }
  {% endif %}

  {% if block.settings.enable_gradient %}
    .ai-background-container-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.gradient_color_1 }} 0%,
        {{ block.settings.gradient_color_2 }} 100%
      );
      opacity: {{ block.settings.gradient_opacity }};
      pointer-events: none;
    }
  {% endif %}

  .ai-background-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-background-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-background-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-background-container-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-background-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-background-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-background-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-background-container-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-background-image-{{ ai_gen_id }}"
      >
    {% endif %}

    <div class="ai-background-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-background-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-background-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
