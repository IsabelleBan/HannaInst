{% doc %}
  @prompt
    Could you generate 4 responsive boxes that will be placed under a Shopify custom Liquid section?
    Requirements:
    
    All four boxes should be displayed beside each other in a row (responsive: 1 column on mobile, 2 on tablet, 4 on desktop).
    
    Each box should have:
    
    An image or SVG at the top.
    
    A title below the image.
    
    Some paragraph text below the title.
    
    Optional list items (bullets) under the paragraph.
    
    Keep the styling clean and minimal, using a light background for the boxes.
    
    The boxes should have consistent padding and height.
    
    The generated code should be ready to copy into a Shopify custom Liquid section, using proper HTML, classes, and inline styles where necessary.
    
    Ensure it is easy to replace the images, titles, and text later in Shopify admin.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-info-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-info-boxes-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-info-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background }};
    padding: {{ block.settings.box_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.content_alignment }};
    text-align: {{ block.settings.content_alignment }};
    height: 100%;
  }

  .ai-info-box-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_width }}px;
    margin-bottom: {{ block.settings.spacing_after_image }}px;
  }

  .ai-info-box-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-info-box-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-info-box-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-info-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing_after_title }}px 0;
  }

  .ai-info-box-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_after_text }}px 0;
    line-height: 1.5;
  }

  .ai-info-box-list-{{ ai_gen_id }} {
    list-style: disc;
    padding-left: 20px;
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-info-box-list-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-info-box-list-{{ ai_gen_id }} li:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-info-boxes-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-info-boxes-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<info-boxes-{{ ai_gen_id }} class="ai-info-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-info-boxes-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign box_image_key = 'box_' | append: i | append: '_image'
        assign box_title_key = 'box_' | append: i | append: '_title'
        assign box_text_key = 'box_' | append: i | append: '_text'
        assign box_list_key = 'box_' | append: i | append: '_list'

        assign box_image = block.settings[box_image_key]
        assign box_title = block.settings[box_title_key]
        assign box_text = block.settings[box_text_key]
        assign box_list = block.settings[box_list_key]
      %}

      <div class="ai-info-box-{{ ai_gen_id }}">
        <div class="ai-info-box-image-wrapper-{{ ai_gen_id }}">
          {% if box_image %}
            <img
              src="{{ box_image | image_url: width: 400 }}"
              alt="{{ box_image.alt | escape }}"
              loading="lazy"
              width="{{ box_image.width }}"
              height="{{ box_image.height }}"
              class="ai-info-box-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-info-box-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if box_title != blank %}
          <h3 class="ai-info-box-title-{{ ai_gen_id }}">{{ box_title }}</h3>
        {% endif %}

        {% if box_text != blank %}
          <div class="ai-info-box-text-{{ ai_gen_id }}">{{ box_text }}</div>
        {% endif %}

        {% if box_list != blank %}
          {% assign list_items = box_list | split: ',' %}
          <ul class="ai-info-box-list-{{ ai_gen_id }}">
            {% for item in list_items %}
              {% assign trimmed_item = item | strip %}
              {% if trimmed_item != blank %}
                <li>{{ trimmed_item }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</info-boxes-{{ ai_gen_id }}>

<script>
  (function() {
    class InfoBoxes{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('info-boxes-{{ ai_gen_id }}', InfoBoxes{{ ai_gen_id }});
  })();
</script>

